func makeAtomicCounter(init int) (async async int, async int) {
    var AsyncGet async async int // comment
    var Inc async int
    var Val async int
    join {
        case from Inc, from Val as val:
            Val <- val + 1
        case from AsyncGet as ReplyCh, from Val as val:
            // Можно ли здесь объявить Join с участием ReplyCh?
            ReplyCh <- val
            Val <- val
    }
    Val <- init
    return AsyncGet, Inc
}

AsyncGet, Inc := makeAtomicCounter(0)
Inc <- 1
Inc <- 1
var Result async int
join {
    case from Result as res:
        print(res)
}
AsyncGet <- Result
